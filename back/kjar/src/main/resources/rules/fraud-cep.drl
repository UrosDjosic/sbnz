package rules;

import com.sbnz.vehicleassessment.model.event.ProcenaSteteEvent;
import com.sbnz.vehicleassessment.model.event.FraudAlert;
import com.sbnz.vehicleassessment.model.enums.TipEskalacije;
import com.sbnz.vehicleassessment.model.enums.TipOdluke;
import java.lang.Number;

// =========================================================
// CEP - nadzor nad istorijom stvarnih procena stete
// =========================================================

rule "CEP 1 - Ponavljane totalne stete za istu sasiju u 180 dana"
when
    $p1 : ProcenaSteteEvent(
        $sasija : brojSasije,
        tipOdluke == TipOdluke.TOTALNA_STETA
    )
    $p2 : ProcenaSteteEvent(
        brojSasije == $sasija,
        tipOdluke == TipOdluke.TOTALNA_STETA,
        this after[1s, 180d] $p1
    )
    not FraudAlert(
        brojSasije == $sasija,
        opis == "Ponavljane totalne stete za istu sasiju u 180 dana"
    )
then
    insert(new FraudAlert($sasija,
        "Ponavljane totalne stete za istu sasiju u 180 dana",
        TipEskalacije.ESKALACIJA));
end

rule "CEP 2 - Tri visokorizicne procene za istu sasiju u 12 meseci"
when
    $p : ProcenaSteteEvent($sasija : brojSasije)
    Number(intValue >= 3) from accumulate(
        ProcenaSteteEvent(
            brojSasije == $sasija,
            procenatStete >= 70.0
        ) over window:time(365d),
        count(1)
    )
    not FraudAlert(
        brojSasije == $sasija,
        opis == "Tri visokorizicne procene za istu sasiju u 12 meseci"
    )
then
    insert(new FraudAlert($sasija,
        "Tri visokorizicne procene za istu sasiju u 12 meseci",
        TipEskalacije.PROVERA));
end

rule "CEP 3 - Akumulirana manja potrazivanja u 90 dana"
when
    $p : ProcenaSteteEvent($sasija : brojSasije)
    Number(doubleValue > 3000.0) from accumulate(
        ProcenaSteteEvent(
            brojSasije == $sasija,
            $n : naknada,
            naknada > 0.0,
            naknada < 1000.0
        ) over window:time(90d),
        sum($n)
    )
    not FraudAlert(
        brojSasije == $sasija,
        opis == "Akumulirana manja potrazivanja u 90 dana"
    )
then
    insert(new FraudAlert($sasija,
        "Akumulirana manja potrazivanja u 90 dana",
        TipEskalacije.PROVERA));
end

rule "CEP 4 - Kriticni sklop kod ponovljene procene iste sasije"
when
    $p1 : ProcenaSteteEvent(
        $sasija : brojSasije,
        imaKriticniSklop == true
    )
    $p2 : ProcenaSteteEvent(
        brojSasije == $sasija,
        imaKriticniSklop == true,
        this after[1s, 180d] $p1
    )
    not FraudAlert(
        brojSasije == $sasija,
        opis == ("Ponovljena ostecenja kriticnih sklopova za sasiju " + $sasija)
    )
then
    insert(new FraudAlert($sasija,
        "Ponovljena ostecenja kriticnih sklopova za sasiju " + $sasija,
        TipEskalacije.STRUCNA_PROVERA));
end
